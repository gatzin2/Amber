--- !u!102 &49892029
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 49892028}
  m_Text: "\u5C18\u7075\u7F16\u5E74\u53F2\u8DEF\u7EBF\u767D\u76D2\r\nDust Chronicle
    Whitebox Route\r\nSample three-lane route map. Replace node names and content
    keys with your authored encounters.\r\n\r\n\u6D41\u7A0B\u72B6\u6001\uFF1ALaneSelection\r\n\u4E0A\u6B21\u7ED3\u679C\uFF1A\u65E0\r\n\u5DF2\u9009\u8DEF\u7EBF\uFF1A\u65E0\r\n\r\n\u6218\u6597\u5FEB\u7167\uFF1A\r\n\u6218\u6597\u72B6\u6001\uFF1ANotStarted\r\n\u6211\u65B9\u5B58\u6D3B\uFF1A3/3\r\n\u654C\u65B9\u5B58\u6D3B\uFF1A4/4\r\n\u5DF2\u7528\u65F6\uFF1A0.0\u79D2\r\n\r\n\u521B\u4F5C\u8DEF\u7EBF\uFF1A\r\n[1]
    Left Route\r\n  - 1. Opening Skirmish [Battle]\r\n  - 2. Supply Stop [Shop]\r\n 
    - 3. Dust Ambush [Battle]\r\n  - 4. Route Finale [Boss]\r\n[2] Center Route\r\n 
    - 1. Collapsed Causeway [Event]\r\n  - 2. Patrol Clash [Battle]\r\n  - 3. Campfire
    [Rest]\r\n  - 4. Vault Door [EliteBattle]\r\n  - 5. Route Finale [Boss]\r\n[3]
    Right Route\r\n  - 1. Broken Market [Shop]\r\n  - 2. Silent Hall [Event]\r\n 
    - 3. Relic Cache [Treasure]\r\n  - 4. Rear Guard [Battle]\r\n  - 5. Route Finale
    [Boss]\r\n"
  m_OffsetZ: 0
  m_CharacterSize: 0.28
  m_LineSpacing: 1
  m_Anchor: 0
  m_Alignment: 0
  m_TabSize: 4
  m_FontSize: 0
  m_FontStyle: 0
  m_RichText: 1
  m_Font: {fileID: 0}
  m_Color:
    serializedVersion: 2
    rgba: 4294963947
